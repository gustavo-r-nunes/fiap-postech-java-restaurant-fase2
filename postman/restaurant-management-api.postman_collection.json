  "item": [
    {
      "name": "01 - Setup",
      "item": [
        {
          "name": "List User Types - Set Default IDs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/user-types",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "user-types"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const userTypes = pm.response.json();",
                  "const dono = userTypes.find(type => type.name && type.name.trim().toLowerCase() === 'dono de restaurante');",
                  "const cliente = userTypes.find(type => type.name && type.name.trim().toLowerCase() === 'cliente');",
                  "",
                  "pm.test('Default user type Dono de Restaurante exists', function () {",
                  "    pm.expect(dono).to.not.be.undefined;",
                  "});",
                  "",
                  "pm.test('Default user type Cliente exists', function () {",
                  "    pm.expect(cliente).to.not.be.undefined;",
                  "});",
                  "",
                  "if (dono) {",
                  "    pm.collectionVariables.set('donoTypeId', dono.id);",
                  "}",
                  "",
                  "if (cliente) {",
                  "    pm.collectionVariables.set('clienteTypeId', cliente.id);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
